# This config is a STUB! This should never be generated.
# Use the default lua config from https://github.com/hyprwm/Hyprland/blob/main/example/hyprland.lua

autogenerated = 0

$mainMod = SUPER
$terminal = kitty
$fileManager = dolphin
$menu = hyprlauncher

env = WLR_RENDERER, vulkan

exec-once = hyprpaper
exec-once = dunst
exec-once = wofi
exec-once = pipewire
exec-once = hyprpanel
exec-once = wl-copy

bind = SUPER, SPACE, exec, wofi --show drun
bind = SUPER, S, exec, hyprshot -m region --clipboard-only
bind = SUPER, F, exec, firefox
bind = SUPER, R, exec, $terminal -e nano /home/main/.config/hypr/hyprland.conf

monitor = eDP-1, 1920x1080@60.00Hz, 1920x0, 1.0
monitor = HDMI-A-1, 1920x1080@74.97Hz, 0x0, 1.0 

bind = $mainMod, Q, exec, $terminal
bind = $mainMod, C, killactive,
bind = $mainMod, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit
bind = $mainMod, E, exec, $fileManager
bind = $mainMod, V, togglefloating,
bind = $mainMod, R, exec, $menu

bind = SUPER, 1, vdesk, 1
bind = SUPER, 2, vdesk, 2
bind = SUPER, 3, vdesk, 3
bind = SUPER, 4, vdesk, 4
bind = SUPER, 5, vdesk, 5
bind = SUPER, 6, vdesk, 6
bind = SUPER, 7, vdesk, 7
bind = SUPER, 8, vdesk, 8
bind = SUPER, 9, vdesk, 9

#bind = SUPER SHIFT, 1, movetovdesk, 1
#bind = SUPER SHIFT, 2, movetovdesk, 2
#bind = SUPER SHIFT, 3, movetovdesk, 3
#bind = SUPER SHIFT, 4, movetovdesk, 4
#bind = SUPER SHIFT, 5, movetovdesk, 5
#bind = SUPER SHIFT, 6, movetovdesk, 6
#bind = SUPER SHIFT, 7, movetovdesk, 7
#bind = SUPER SHIFT, 8, movetovdesk, 8
#bind = SUPER SHIFT, 9, movetovdesk, 9

bind = SUPER, bracketleft, vdesk, prev
bind = SUPER, bracketright, vdesk, next
